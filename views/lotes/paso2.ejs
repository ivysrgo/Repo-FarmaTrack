<%# views/lotes/paso2.ejs — Traslado de materias primas %>
<div class="step-page">
  <%- include('../partials/stepper-topbar') %>

  <div class="step-layout">
    <div class="step-main">

      <div class="step-header">
        <div class="step-header__meta">
          <span>Paso 2/9 · <%= lote.numeroLote %> · <%= lote.medicamento %> · Operario: <%= operario.nombre %></span>
          <span class="step-header__badge step-header__badge--readonly">🔒 Solo lectura · D.T.</span>
          <span class="step-header__timer">⏱ <%= tiempoTranscurrido %></span>
        </div>
        <h1 class="step-header__title">Traslado de materias primas</h1>
      </div>

      <div class="readonly-notice">🔒 Vista de solo lectura — Director Técnico. Este paso fue completado por el Operario.</div>

      <!-- Tabla de materias primas -->
      <div class="step-card">
        <p class="step-card__title">Materias primas trasladadas al laboratorio</p>
        <div class="info-notice" style="margin-bottom:10px">
          📋 Registro de traslado completado por operario <%= operario.nombre %>. Todos los campos son de solo lectura.
        </div>
        <table class="step-table">
          <thead>
            <tr>
              <th>Materia prima</th>
              <th>Cant. esperada</th>
              <th>Cant. recibida</th>
              <th>Estado</th>
              <th>Recibida</th>
            </tr>
          </thead>
          <tbody>
            <% materias.forEach(m => { %>
              <tr>
                <td><%= m.nombre %></td>
                <td><%= m.esperada %></td>
                <td><%= m.recibida %></td>
                <td><span class="badge-conforme">✓ <%= m.estado %></span></td>
                <td><span class="badge-si">✓ Sí</span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div style="margin-top:12px">
          <p class="obs-label">Observaciones del operario</p>
          <div class="field-value field-value--wide"><%= observaciones %></div>
        </div>
      </div>

      <!-- Checklist -->
      <div class="step-card">
        <p class="step-card__title">Checklist completado</p>
        <div class="checklist-grid">
          <% checklist.forEach(item => { %>
            <div class="check-row">
              <div class="check-box"></div>
              <span><%= item %></span>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="step-card">
        <p class="obs-label">Observaciones del operario (solo lectura)</p>
        <div class="field-value field-value--wide" style="color:var(--muted)">Sin observaciones adicionales registradas en este paso.</div>
      </div>

    </div>

    <%- include('../partials/stepper-aside') %>
  </div>

  <%- include('../partials/stepper-footer') %>
</div>
