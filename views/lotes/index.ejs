<%# views/lotes/index.ejs — Panel de Lotes Activos %>

<!-- Encabezado de página -->
<div class="page-header">
  <div>
    <h1 class="page-title">Lotes Activos</h1>
    <p class="page-subtitle">Panel de supervisión — Módulo de Producción</p>
  </div>
  <a href="/lotes/nuevo" class="btn btn--primary">+ Nueva Orden</a>
</div>

<!-- Estadísticas rápidas -->
<div class="stats-grid">
  <div class="stat-card">
    <span class="stat-card__icon">🏭</span>
    <div>
      <p class="stat-card__label">En Producción</p>
      <p class="stat-card__value"><%= stats.enProduccion %></p>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-card__icon">⚠️</span>
    <div>
      <p class="stat-card__label">Bloqueados</p>
      <p class="stat-card__value stat-card__value--warning"><%= stats.bloqueados %></p>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-card__icon">✅</span>
    <div>
      <p class="stat-card__label">Liberados Hoy</p>
      <p class="stat-card__value stat-card__value--success"><%= stats.liberadosHoy %></p>
    </div>
  </div>
  <div class="stat-card">
    <span class="stat-card__icon">🔬</span>
    <div>
      <p class="stat-card__label">Total Activos</p>
      <p class="stat-card__value"><%= stats.total %></p>
    </div>
  </div>
</div>

<!-- Barra de búsqueda y filtros -->
<div class="card filter-bar">
  <form method="GET" action="/lotes" class="filter-form">
    <div class="filter-form__search">
      <span class="filter-form__search-icon">🔍</span>
      <input
        type="text"
        name="q"
        class="form-control filter-form__input"
        placeholder="Buscar por N.º lote, medicamento u operario…"
        value="<%= typeof query !== 'undefined' ? query : '' %>"
      />
    </div>
    <div class="filter-form__selects">
      <select name="estado" class="form-control filter-form__select">
        <option value="">Todos los estados</option>
        <option value="en_produccion"  <%= typeof estadoFiltro !== 'undefined' && estadoFiltro === 'en_produccion'  ? 'selected' : '' %>>En producción</option>
        <option value="bloqueado"      <%= typeof estadoFiltro !== 'undefined' && estadoFiltro === 'bloqueado'      ? 'selected' : '' %>>Bloqueado</option>
        <option value="en_espera"      <%= typeof estadoFiltro !== 'undefined' && estadoFiltro === 'en_espera'      ? 'selected' : '' %>>En espera</option>
        <option value="liberado"       <%= typeof estadoFiltro !== 'undefined' && estadoFiltro === 'liberado'       ? 'selected' : '' %>>Liberado</option>
        <option value="rechazado"      <%= typeof estadoFiltro !== 'undefined' && estadoFiltro === 'rechazado'      ? 'selected' : '' %>>Rechazado</option>
      </select>
      <button type="submit" class="btn btn--secondary">Filtrar</button>
      <a href="/lotes" class="btn btn--ghost">Limpiar</a>
    </div>
  </form>
</div>

<!-- Tabla de lotes -->
<% if (lotes.length === 0) { %>
  <div class="empty-state">
    <p class="empty-state__icon">🔬</p>
    <h2>Sin lotes activos</h2>
    <p>No se encontraron lotes con los filtros actuales.</p>
    <a href="/lotes/nuevo" class="btn btn--primary">Crear orden de producción</a>
  </div>
<% } else { %>
  <div class="card">
    <div class="table-wrapper">
      <table class="table">
        <thead>
          <tr>
            <th>N.º Lote</th>
            <th>Medicamento</th>
            <th>Operario</th>
            <th>Estado</th>
            <th>Paso</th>
            <th>Progreso</th>
            <th>Inicio</th>
            <th class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% lotes.forEach(lote => { %>
            <tr class="<%= lote.estado === 'bloqueado' ? 'table__row--warning' : '' %>">

              <!-- N.º Lote -->
              <td>
                <a href="/lotes/<%= lote.id %>" class="table__link table__link--mono">
                  <%= lote.numeroLote %>
                </a>
              </td>

              <!-- Medicamento -->
              <td>
                <p class="table__main"><%= lote.medicamento %></p>
                <p class="table__sub"><%= lote.cantidadPlanificada %> unid. planificadas</p>
              </td>

              <!-- Operario -->
              <td>
                <div class="cell-user">
                  <div class="avatar avatar--sm"><%= lote.operarioInicial %></div>
                  <span class="cell-user__name"><%= lote.operario %></span>
                </div>
              </td>

              <!-- Estado -->
              <td>
                <% 
                  const estadoClases = {
                    en_produccion: 'badge--active',
                    bloqueado:     'badge--warning',
                    en_espera:     'badge--pending',
                    liberado:      'badge--liberated',
                    rechazado:     'badge--error'
                  };
                  const estadoLabels = {
                    en_produccion: 'En producción',
                    bloqueado:     'Bloqueado',
                    en_espera:     'En espera',
                    liberado:      'Liberado',
                    rechazado:     'Rechazado'
                  };
                %>
                <span class="badge <%= estadoClases[lote.estado] || '' %>">
                  <%= lote.estado === 'bloqueado' ? '⚠ ' : '' %><%= estadoLabels[lote.estado] || lote.estado %>
                </span>
              </td>

              <!-- Paso actual -->
              <td class="text-center">
                <span class="step-pill">
                  Paso <%= lote.pasoActual %> / 9
                </span>
              </td>

              <!-- Progreso visual -->
              <td>
                <div class="progress-track">
                  <% for (let i = 1; i <= 9; i++) { %>
                    <div class="progress-track__dot
                      <%= i < lote.pasoActual  ? 'progress-track__dot--done'    : '' %>
                      <%= i === lote.pasoActual ? 'progress-track__dot--active'  : '' %>
                      <%= i > lote.pasoActual  ? 'progress-track__dot--pending' : '' %>
                    "></div>
                  <% } %>
                </div>
              </td>

              <!-- Fecha inicio -->
              <td class="text-muted text-sm">
                <%= new Date(lote.fechaInicio).toLocaleDateString('es-CO', { day:'2-digit', month:'short', year:'numeric' }) %>
              </td>

              <!-- Acciones -->
              <td class="text-right">
                <div class="actions">
                  <a href="/lotes/<%= lote.id %>" class="btn btn--sm btn--ghost" title="Ver detalle">👁</a>
                  <% if (lote.estado === 'bloqueado') { %>
                    <a href="/lotes/<%= lote.id %>/no-conformidades" class="btn btn--sm btn--alert" title="Revisar no conformidad">⚠️</a>
                  <% } %>
                </div>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
